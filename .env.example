URP_BASE_URL=https://jws.qgxy.cn
# 学号
URP_USERNAME=
# 密码
URP_PASSWORD=

# 默认满分
URP_DEFAULT_CHOICE=A
# 默认的评教评论
URP_DEFAULT_COMMENT=老师教学认真课程收获较大

# 提交前等待秒数；教务系统强制等待 120 秒
URP_EVALUATION_WAIT_SECONDS=120
# 可选限制最大评教课程数，一般不用填
# URP_EVALUATION_LIMIT=1
# 并发打开/提交评教课程数。默认 3
URP_EVALUATION_CONCURRENCY=3

# 持续抢课最大尝试次数；0 表示持续运行直到成功或手动停止
URP_COURSE_SNATCHING_ATTEMPTS=0
# 持续抢课并发数，默认 10
URP_COURSE_SNATCHING_CONCURRENCY=10
# 持续抢课每轮请求间隔秒数，默认 0.2
URP_COURSE_SNATCHING_RETRY_INTERVAL=0.2
